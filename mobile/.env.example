# GramChain Mobile — Environment Variables
# Copy this file to .env and fill in your values

# ─── Backend API URL ─────────────────────────────────────────
# Leave empty in development — auto-detects your machine's IP via Metro
EXPO_PUBLIC_API_URL=https://gramchain.onrender.com/api/v1

# ─── Google OAuth Client IDs ─────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Android client ID: from google-services.json (oauth_client where client_type=1)
# iOS client ID: from GoogleService-Info.plist (CLIENT_ID key)
# Web client ID: OAuth 2.0 Web Client (used for token exchange with Firebase)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=51986108180-7ue8padqdchc8qqe599adqc22b7n2ji9.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=51986108180-0rderk57ou6h3k2hf9k2g64bq5f4kp5h.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=51986108180-th7bmld9if0c8l57fsuvur9frjvfvg5m.apps.googleusercontent.com
