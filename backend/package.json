{
  "name": "gramchain-backend",
  "version": "1.0.0",
  "description": "GramChain DeFi Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc && tsc-alias",
