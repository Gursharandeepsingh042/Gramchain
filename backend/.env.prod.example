# ═══════════════════════════════════════════════════════════════
# GramChain — Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.prod and fill in all values.
# All vars marked [REQUIRED] will crash the server on startup if missing.
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000

# ─── [REQUIRED] Database (Supabase PostgreSQL) ──────────────
# Get from: Supabase → Project Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# ─── [REQUIRED] Redis (Upstash / ElastiCache / self-hosted) ─
# Used for: BullMQ job queues, refresh token store, ML score cache
REDIS_URL=redis://:password@<REDIS_HOST>:6379

# ─── [REQUIRED] JWT (min 32 chars each) ─────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<min-64-char-random-hex>
JWT_REFRESH_SECRET=<min-64-char-random-hex>

# ─── [REQUIRED] Blockchain (Polygon) ────────────────────────
# Backend wallet signs all on-chain transactions (loan create, EMI mark, etc.)
# TODO: Move to AWS KMS / GCP Cloud KMS for production (SEC1)
POLYGON_RPC_URL=https://polygon-rpc.com
BACKEND_PRIVATE_KEY=0x<64-hex-chars>
BACKEND_WALLET_ADDRESS=0x<backend-signer-address>

# Contract addresses (auto-populated by deploy script → contracts.json)
LOAN_MANAGER_ADDRESS=0x<deployed-address>
SHG_POOL_FACTORY_ADDRESS=0x<deployed-address>
CREDIT_SCORE_REGISTRY_ADDRESS=0x<deployed-address>

# ─── [REQUIRED] Encryption Key ──────────────────────────────
# Used for AES-256-GCM encryption of KYC data at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TODO: Move to KMS for production (SEC10)
ENCRYPTION_KEY=<64-char-hex>

# ─── [REQUIRED] KYC API (Sandbox → Production) ──────────────
# Sandbox docs: https://docs.setu.co/
SANDBOX_API_KEY=<your-sandbox-api-key>
SANDBOX_API_SECRET=<your-sandbox-api-secret>

# ─── [REQUIRED] ML Service ──────────────────────────────────
# Internal shared secret between backend and ML FastAPI service
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ML_SERVICE_URL=http://ml-service:8000
ML_INTERNAL_SECRET=<strong-random-string>

# ─── [REQUIRED] Firebase (Push Notifications) ───────────────
# Service account JSON (single-line, escaped)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"gramchain",...}
FIREBASE_PROJECT_ID=gramchain

# ─── [REQUIRED] Google Auth ─────────────────────────────────
GOOGLE_CLIENT_ID=<firebase-web-client-id>.apps.googleusercontent.com

# ─── Demo Mode (MUST be false in production) ────────────────
DEMO_MODE=false

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://gramchain.in,gramchain://

# ─── [OPTIONAL] Payment Gateway (Razorpay) ─────────────────
# Set these to enable real UPI/card payments (P1)
# Test keys from: https://dashboard.razorpay.com → Account → API Keys
# Webhook secret from: Razorpay Dashboard → Webhooks → Configure
RAZORPAY_KEY_ID=rzp_live_<key>
RAZORPAY_KEY_SECRET=<secret>
RAZORPAY_WEBHOOK_SECRET=<webhook-secret>

# ─── [OPTIONAL] Blockchain Deployment ───────────────────────
# Only needed for deploying/upgrading contracts, not for runtime
# DEPLOYER_PRIVATE_KEY=0x<64-hex-chars>
# POLYGONSCAN_API_KEY=<key>

# ─── [OPTIONAL] Twilio (if using SMS OTP instead of Firebase)
# TWILIO_SID=AC<xxxx>
# TWILIO_TOKEN=<xxxx>
# TWILIO_PHONE=+1234567890

# ─── [OPTIONAL] Sentry Observability ───────────────────────
# Create a project at https://sentry.io and paste the Node DSN
# Leave blank to disable (zero overhead when unset)
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_TRACES_SAMPLE_RATE=0.05

# ─── [OPTIONAL] Secrets Provider ────────────────────────────
# 'env' (default) | 'aws' | 'gcp' | 'vault'
# When set to aws/gcp/vault, secrets are fetched from the KMS instead of env
# SECRET_PROVIDER=aws
# AWS_REGION=ap-south-1
# AWS_SECRET_PREFIX=gramchain/prod/

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
