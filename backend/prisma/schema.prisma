// This is your Prisma schema file for GramChain
// Targeting Supabase (PostgreSQL) as database

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum KycStatus {
  PENDING
  VERIFIED
  FAILED
}

enum UserRole {
  BORROWER
  LENDER
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  REPAID
  DEFAULTED
}

enum MemberRole {
  MEMBER
  LEADER
}

enum RepaymentStatus {
  CONFIRMED
  FAILED
}

enum LedgerType {
  LENDER_DEPOSIT
  LOAN_DISBURSAL
  EMI_RECEIVED
  INTEREST_ACCRUED
  PLATFORM_FEE
  DEFAULT_WRITEOFF
  PAYMENT_CAPTURE   // P1: Razorpay payment captured
  PAYMENT_REFUND    // P1: Razorpay refund issued
}

enum PaymentStatus {
  CREATED    // Order created, awaiting checkout
  ATTEMPTED  // User initiated checkout, signature pending
  CAPTURED   // Razorpay confirmed capture
  FAILED     // Capture failed / user abandoned
  REFUNDED   // Refund issued
}

enum OutboxJobStatus {
  PENDING   // Not yet sent to BullMQ
  QUEUED    // Picked up and placed in BullMQ
  FAILED    // Exhausted retries
}

enum NotificationType {
  LOAN_APPROVAL_REQUEST  // Member applied for loan — sent to group
  LOAN_APPROVED          // Leader approved a loan
  LOAN_REJECTED          // Leader rejected a loan
  LOAN_OPPORTUNITY       // New loan opportunity for lenders
  MEMBER_REMOVED         // User was removed from group
  GROUP_INVITE           // Invited to join a group
  DISSOLUTION_VOTE       // Group leader started dissolution vote
  KYC_REMINDER           // Reminder to complete KYC
  GROUP_FUNDING_REQUEST  // SHG leader applied for group funding — sent to lenders
  GROUP_FUNDING_APPROVED // Lender approved group funding
  GENERAL                // Generic notification
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  phone         String?   @unique
  googleId      String?   @unique
  email         String?   @unique
  aadhaarHash   String?   @unique
  panHash       String?   @unique
  walletAddress String?   @unique
  role               UserRole  @default(BORROWER)
  kycStatus         KycStatus @default(PENDING)
  kycDetails        String?   // AES-256-GCM encrypted JSON string (NOT raw Json type)
  name              String?
  fcmToken          String?   // Firebase push token
  password          String?   // Hashed password for phone login
  preferredLanguage String    @default("en") // 'en' or 'hi'
  lastKycReminderAt DateTime? // Last time KYC pending reminder was sent
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  shgMemberships SHGMember[]
  loans          Loan[]
  bankAccounts   BankAccount[]
  notifications  Notification[]
  paymentOrders  PaymentOrder[]
  fundingRequests GroupFundingRequest[] @relation("FundingRequestor")
  investments     LenderInvestment[] @relation("LenderInvestments")

  @@map("users")
}

enum FundingStatus {
  PENDING
  APPROVED
  REJECTED
  FULLY_FUNDED
  DISBURSED
}

model SHGGroup {
  id                      String    @id @default(cuid())
  name                    String
  district                String
  state                   String
  village                 String?
  poolContractAddress     String?
  description             String?
  inviteCode              String?   @unique
  isActive                Boolean   @default(true)
  dissolutionRequestedAt  DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  members          SHGMember[]
  loans            Loan[]
  meetings         Meeting[]
  dissolutionVotes DissolutionVote[]
  fundingRequests  GroupFundingRequest[]
  investments      LenderInvestment[] @relation("GroupInvestments")

  @@map("shg_groups")
}

model DissolutionVote {
  id        String   @id @default(cuid())
  shgId     String
  userId    String
  vote      Boolean  // true = YES (dissolve), false = NO (keep)
  createdAt DateTime @default(now())

  shg SHGGroup @relation(fields: [shgId], references: [id], onDelete: Cascade)

  @@unique([shgId, userId])
  @@map("dissolution_votes")
}

model SHGMember {
  userId   String
  shgId    String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shg  SHGGroup @relation(fields: [shgId], references: [id], onDelete: Cascade)

  @@id([userId, shgId])
  @@map("shg_members")
}

model Loan {
  id              String     @id @default(cuid())
  memberId        String
  shgId           String
  amount          Decimal    @db.Decimal(18, 2) // INR with 2 decimal places (rupees.paise)
  interestRateBps Int        // e.g. 1800 = 18% APR in basis points
  tenureMonths    Int
  purpose         String?
  mlScore         Int?
  mlRiskBand      String?
  status          LoanStatus @default(PENDING)
  contractLoanId  Int?       // On-chain loan ID (null until blockchain confirms)
  isSyncedOnChain Boolean    @default(false) // True once contractLoanId is populated
  disbursedAt     DateTime?
  txHash          String?    // On-chain create tx hash
  nextEmiDue      DateTime?
  emiAmount       Decimal?   @db.Decimal(18, 2)
  emisPaid        Int        @default(0)  // Track how many EMIs have been paid (mirror of chain)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  member     User        @relation(fields: [memberId], references: [id])
  shg        SHGGroup    @relation(fields: [shgId], references: [id])
  repayments Repayment[]

  @@index([memberId])
  @@index([status])              // DB7: standalone status index for common filters
  @@index([status, nextEmiDue])
  @@index([contractLoanId])
  @@index([isSyncedOnChain]) // Useful for drift-audit queries
  @@map("loans")
}

// ─────────────────────────────────────────────
// Transactional Outbox: Guarantees blockchain writes
// survive crashes between DB commit and Redis enqueue.
// A cron job or startup sweep picks up PENDING jobs.
// ─────────────────────────────────────────────
model OutboxJob {
  id          String          @id @default(cuid())
  jobName     String          // 'create-loan' | 'approve-loan' | 'mark-disbursed' | 'mark-emi' | 'record-score'
  jobData     Json            // Payload to send to BullMQ worker
  status      OutboxJobStatus @default(PENDING)
  attempts    Int             @default(0)
  lastError   String?
  createdAt   DateTime        @default(now())
  processedAt DateTime?       // When it was enqueued in BullMQ

  @@index([status, createdAt]) // For fast sweep queries
  @@map("outbox_jobs")
}

model FailedBlockchainJob {
  id        String   @id @default(cuid())
  jobName   String
  jobData   Json
  error     String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("failed_blockchain_jobs")
}

model Repayment {
  id      String          @id @default(cuid())
  loanId  String
  amount  Decimal         @db.Decimal(18, 2)
  paidAt  DateTime        @default(now())
  txHash  String          @unique
  upiRef  String?         // Raw UPI reference (before hashing for on-chain)
  status  RepaymentStatus @default(CONFIRMED)

  loan Loan @relation(fields: [loanId], references: [id])

  @@index([loanId])
  @@map("repayments")
}

model Meeting {
  id        String   @id @default(cuid())
  shgId     String
  heldAt    DateTime
  attendees Json     // Array of user IDs
  notes     String?
  createdAt DateTime @default(now())

  shg SHGGroup @relation(fields: [shgId], references: [id])

  @@map("meetings")
}

model OtpRecord {
  phone        String   @id
  otp          String
  expiresAt    DateTime
  attempts     Int      @default(0)
  requestCount Int      @default(0) // Number of OTP send requests in the current window
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([expiresAt])
  @@map("otp_records")
}

model LedgerEntry {
  id               String     @id @default(cuid())
  entityType       String     // 'user' | 'shg' | 'loan'
  entityId         String
  type             LedgerType
  amountPaise      Int        // always in paise (positive = credit, negative = debit)
  balancePaise     Int        // running balance snapshot
  ref              String?    // UPI ref / tx hash
  chainProcessedAt DateTime?  // DB3: When this entry was processed on-chain (idempotency)
  createdAt        DateTime   @default(now())

  @@index([entityType, entityId, createdAt]) // For fast running-balance queries
  @@unique([entityType, entityId, ref])      // DB5: Prevent duplicate ledger entries
  @@map("ledger_entries")
}

// ─────────────────────────────────────────────
// Blockchain sync tracker — persists the last
// block processed by the event listener so restarts
// don't miss historical events.
// ─────────────────────────────────────────────
model BlockchainSyncState {
  id               String   @id @default("singleton") // Only one row ever exists
  lastProcessedBlock Int    @default(0)
  updatedAt        DateTime @updatedAt

  @@map("blockchain_sync_state")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?            // Extra payload e.g. { loanId, shgId }
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([type])  // DB7: index for filtering by notification type
  @@map("notifications")
}

model BankAccount {
  id            String    @id @default(cuid())
  userId        String
  bankName      String
  accountNumber String    // Last 4 digits stored masked for display
  ifsc          String
  verified      Boolean   @default(false)
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_accounts")
}

// ─────────────────────────────────────────────
// DB2: Drift Alert — tracks discrepancies between
// on-chain state and database state for reconciliation.
// Created by the reconcile worker when it finds mismatches.
// ─────────────────────────────────────────────
model DriftAlert {
  id         String    @id @default(cuid())
  loanId     String
  field      String    // e.g. 'status', 'emisPaid', 'disbursedAt'
  dbValue    String    // Value in PostgreSQL
  chainValue String    // Value on-chain
  severity   String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?   // userId who resolved it
  createdAt  DateTime  @default(now())

  @@index([resolved, createdAt])
  @@index([loanId])
  @@map("drift_alerts")
}

// ─────────────────────────────────────────────
// P1: Razorpay payment orders — tracks every
// checkout session from order creation to capture.
// Idempotency: (razorpayOrderId) is UNIQUE.
// ─────────────────────────────────────────────
model PaymentOrder {
  id               String        @id @default(cuid())
  userId           String
  razorpayOrderId  String        @unique
  razorpayPaymentId String?      // Populated on capture
  amountPaise      Int
  currency         String        @default("INR")
  purpose          String        // 'loan-emi' | 'loan-disbursal' | 'shg-contribution'
  refType          String        // 'loan' | 'repayment' | 'shg'
  refId            String        // ID of the loan / repayment / SHG
  status           PaymentStatus @default(CREATED)
  signature        String?       // Client-side Razorpay signature (stored for audit)
  failureReason    String?
  capturedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([refType, refId])
  @@map("payment_orders")
}

// ─────────────────────────────────────────────
// Group Funding Models — for SHG group funding from lenders
// ─────────────────────────────────────────────
model GroupFundingRequest {
  id              String        @id @default(cuid())
  shgId           String
  requestedBy     String        // userId of SHG leader
  amount          Decimal       @db.Decimal(18, 2)
  durationMonths  Int
  purpose         String
  minInvestment   Decimal       @db.Decimal(18, 2) // Minimum per lender
  maxInvestment   Decimal       @db.Decimal(18, 2) // Maximum per lender (max 1 lakh)
  signatureUrl    String?       // Leader signature image URL
  termsAccepted   Boolean       @default(false)
  status          FundingStatus @default(PENDING)
  disbursedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  shg      SHGGroup            @relation(fields: [shgId], references: [id])
  requestor User                @relation("FundingRequestor", fields: [requestedBy], references: [id])
  investments LenderInvestment[]

  @@index([shgId, status])
  @@index([status])
  @@map("group_funding_requests")
}

model LenderInvestment {
  id              String        @id @default(cuid())
  fundingRequestId String
  lenderId        String
  shgId           String        // Direct link to SHG for easier querying
  amount          Decimal       @db.Decimal(18, 2)
  interestRateBps Int           // Interest rate in basis points
  status          FundingStatus @default(PENDING)
  approvedAt      DateTime?
  declinedAt      DateTime?
  txHash          String?       // Blockchain transaction hash
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  fundingRequest GroupFundingRequest @relation(fields: [fundingRequestId], references: [id])
  lender         User                @relation("LenderInvestments", fields: [lenderId], references: [id])
  shg            SHGGroup            @relation("GroupInvestments", fields: [shgId], references: [id])

  @@index([fundingRequestId, status])
  @@index([lenderId, status])
  @@index([shgId, status])
  @@map("lender_investments")
}
